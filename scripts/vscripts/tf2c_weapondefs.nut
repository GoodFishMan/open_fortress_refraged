getroottable()["GetWeaponDefById"] <- function(itemDefId)
{
	foreach (d in g_WeaponDefs) if (d.id == itemDefId) return d;
	return null;
}

getroottable()["GetWeaponDefByWorldModel"] <- function(modelPath)
{
	if (modelPath == null) return null;
	local key = modelPath.tolower();
	if (!(key in g_ModelWorldToWeaponId)) return null;
	return GetWeaponDefById(g_ModelWorldToWeaponId[key]);
}
// Compatibility alias for scripts that expect snake_case
::g_weaponDefs <- ::g_WeaponDefs;