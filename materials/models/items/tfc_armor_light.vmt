"VertexLitGeneric"
{
	"$baseTexture" "models/items/tfc_armor_light"
	"$selfillum" "1"


	// Use separate self-illum mask on Pre DX9 hardware
	">=DX90"
	{
		"$baseTexture" 		"models/items/tfc_armor_light"
		"$selfillummask" 	"models/items/item_selfillum"
	}

	// Use redundant self-illum in base alpha on Pre DX9 hardware
	"<DX90"
	{
		"$baseTexture" 	"models/items/tfc_armor_light"
	}
}
